<codeline></codeline>
<codeline><highlight class="normal">-<sp/>Binds<sp/>value<sp/>in<sp/>global<sp/>environment</highlight></codeline>
<codeline><highlight class="normal">-<sp/>Function<sp/>form<sp/>expands<sp/>to<sp/>lambda</highlight></codeline>
<codeline></codeline>
