# Doxyfile for Aperture Language Documentation

#---------------------------------------------------------------------------
# Project related configuration
#---------------------------------------------------------------------------

PROJECT_NAME           = "Aperture Language"
PROJECT_NUMBER         = "1.0.0"
PROJECT_BRIEF          = "Security-focused programming language with apertures"
PROJECT_LOGO           = 
OUTPUT_DIRECTORY       = docs/api
CREATE_SUBDIRS         = YES
OUTPUT_LANGUAGE        = English

#---------------------------------------------------------------------------
# Build configuration
#---------------------------------------------------------------------------

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
EXTRACT_LOCAL_METHODS  = YES

SHOW_INCLUDE_FILES     = YES
INLINE_INHERITED_MEMB  = YES
FULL_PATH_NAMES        = YES
STRIP_FROM_PATH        = /home/spinoza/github/repos/aperture/

MULTILINE_CPP_IS_BRIEF = YES
TAB_SIZE               = 4

#---------------------------------------------------------------------------
# Input configuration
#---------------------------------------------------------------------------

INPUT                  = secure_lang_documented.hpp \
                        secure_lang.cpp \
                        fluent_api.hpp \
                        test_framework.hpp \
                        docs/DESIGN.md \
                        README.md \
                        CLAUDE.md

INPUT_ENCODING         = UTF-8
FILE_PATTERNS          = *.cpp *.hpp *.h *.md
RECURSIVE              = YES
EXCLUDE_PATTERNS       = */build/* */tests/* *_test.cpp

USE_MDFILE_AS_MAINPAGE = docs/DESIGN.md

#---------------------------------------------------------------------------
# Output configuration  
#---------------------------------------------------------------------------

GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html
HTML_COLORSTYLE_HUE    = 220
HTML_COLORSTYLE_SAT    = 100
HTML_COLORSTYLE_GAMMA  = 80
HTML_DYNAMIC_SECTIONS  = YES
HTML_TIMESTAMP         = YES

GENERATE_LATEX         = NO
GENERATE_RTF           = NO
GENERATE_MAN           = NO
GENERATE_XML           = YES
XML_OUTPUT             = xml

#---------------------------------------------------------------------------
# Preprocessing
#---------------------------------------------------------------------------

ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = NO
SEARCH_INCLUDES        = YES
INCLUDE_PATH           = 
PREDEFINED             = 

#---------------------------------------------------------------------------
# Diagrams
#---------------------------------------------------------------------------

HAVE_DOT               = YES
DOT_NUM_THREADS        = 0
CLASS_DIAGRAMS         = YES
HIDE_UNDOC_RELATIONS   = NO
CLASS_GRAPH            = YES
COLLABORATION_GRAPH    = YES
GROUP_GRAPHS           = YES
INCLUDE_GRAPH          = YES
INCLUDED_BY_GRAPH      = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
GRAPHICAL_HIERARCHY    = YES
DIRECTORY_GRAPH        = YES

DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES
DOT_TRANSPARENT        = YES

#---------------------------------------------------------------------------
# Documentation features
#---------------------------------------------------------------------------

ALPHABETICAL_INDEX     = YES
GENERATE_TREEVIEW      = YES
TREEVIEW_WIDTH         = 250
SORT_MEMBER_DOCS       = YES
SORT_BRIEF_DOCS        = YES
SORT_MEMBERS_CTORS_1ST = YES
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES
USE_HTAGS              = NO
VERBATIM_HEADERS       = YES

#---------------------------------------------------------------------------
# Search configuration
#---------------------------------------------------------------------------

SEARCHENGINE           = YES
SERVER_BASED_SEARCH    = NO

#---------------------------------------------------------------------------
# LaTeX configuration
#---------------------------------------------------------------------------

GENERATE_LATEX         = NO

#---------------------------------------------------------------------------
# External references
#---------------------------------------------------------------------------

TAGFILES               = 
GENERATE_TAGFILE       = docs/api/aperture.tag
ALLEXTERNALS           = NO
EXTERNAL_GROUPS        = YES

#---------------------------------------------------------------------------
# Examples and code snippets
#---------------------------------------------------------------------------

EXAMPLE_PATH           = examples
EXAMPLE_PATTERNS       = *.cpp *.aperture
EXAMPLE_RECURSIVE      = YES

#---------------------------------------------------------------------------
# Warnings and progress
#---------------------------------------------------------------------------

QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = YES
WARN_FORMAT            = "$file:$line: $text"
WARN_LOGFILE           = docs/doxygen_warnings.log