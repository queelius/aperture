<sect2 id="index_1autotoc_md29">
<title>Operator Overloading</title>
<para><programlisting filename=".cpp"><codeline><highlight class="comment">//<sp/>Arithmetic</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal">expr1<sp/>+<sp/>expr2<sp/><sp/><sp/></highlight><highlight class="comment">//<sp/>(+<sp/>expr1<sp/>expr2)</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal">expr1<sp/>-<sp/>expr2<sp/><sp/><sp/></highlight><highlight class="comment">//<sp/>(-<sp/>expr1<sp/>expr2)</highlight><highlight class="normal"></highlight></codeline>
