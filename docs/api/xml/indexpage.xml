<para><programlisting filename=".cpp"><codeline><highlight class="keyword">namespace<sp/></highlight><highlight class="normal"><ref refid="dc/d1b/namespaceaperture_1_1build" kindref="compound">aperture::build</ref><sp/>{</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><ref refid="d9/ddc/classaperture_1_1Expr" kindref="compound">Expr</ref><sp/><ref refid="dc/d1b/namespaceaperture_1_1build_1a6a50c75c9bd356f7389b861115a53f80" kindref="member">hole</ref>(</highlight><highlight class="keyword">const</highlight><highlight class="normal"><sp/>std::string&amp;<sp/>name);</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><ref refid="d9/ddc/classaperture_1_1Expr" kindref="compound">Expr</ref><sp/><ref refid="dc/d1b/namespaceaperture_1_1build_1a65b4207ecbcf6370a69baad6d26ae2e6" kindref="member">num</ref>(</highlight><highlight class="keywordtype">double</highlight><highlight class="normal"><sp/>n);</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><ref refid="d9/ddc/classaperture_1_1Expr" kindref="compound">Expr</ref><sp/><ref refid="dc/d1b/namespaceaperture_1_1build_1a4ccc0a2913956a87f7a1f8381624803b" kindref="member">sym</ref>(</highlight><highlight class="keyword">const</highlight><highlight class="normal"><sp/>std::string&amp;<sp/>s);</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><ref refid="d9/ddc/classaperture_1_1Expr" kindref="compound">Expr</ref><sp/>str(</highlight><highlight class="keyword">const</highlight><highlight class="normal"><sp/>std::string&amp;<sp/>s);</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/></highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/></highlight><highlight class="comment">//<sp/>Convenience<sp/>hole<sp/>builders</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><ref refid="d9/ddc/classaperture_1_1Expr" kindref="compound">Expr</ref><sp/><ref refid="dc/d1b/namespaceaperture_1_1build_1ad5ad3a520e632a4547720c931b53ad68" kindref="member">x</ref>();<sp/><sp/></highlight><highlight class="comment">//<sp/>hole(&quot;x&quot;)</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><ref refid="d9/ddc/classaperture_1_1Expr" kindref="compound">Expr</ref><sp/><ref refid="dc/d1b/namespaceaperture_1_1build_1a840a8a34752dac04242b1ca919af1ede" kindref="member">y</ref>();<sp/><sp/></highlight><highlight class="comment">//<sp/>hole(&quot;y&quot;)</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><ref refid="d9/ddc/classaperture_1_1Expr" kindref="compound">Expr</ref><sp/><ref refid="dc/d1b/namespaceaperture_1_1build_1af3ce86ababe360c2bfd17cc68bffa553" kindref="member">z</ref>();<sp/><sp/></highlight><highlight class="comment">//<sp/>hole(&quot;z&quot;)</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal">}</highlight></codeline>
