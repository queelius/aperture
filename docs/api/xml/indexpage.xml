<codeline><highlight class="normal"></highlight><highlight class="keyword">auto</highlight><highlight class="normal"><sp/>expr2<sp/>=<sp/><ref refid="dc/d1b/namespaceaperture_1_1build_1a6a50c75c9bd356f7389b861115a53f80" kindref="member">hole</ref>(</highlight><highlight class="stringliteral">&quot;x&quot;</highlight><highlight class="normal">);</highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="keyword">auto</highlight><highlight class="normal"><sp/>expr3<sp/>=<sp/>expr1<sp/>+<sp/>expr2;<sp/><sp/></highlight><highlight class="comment">//<sp/>(+<sp/>42<sp/>?x)</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="comment">//<sp/>Complex<sp/>expressions</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="keyword">auto</highlight><highlight class="normal"><sp/>formula<sp/>=<sp/>(<ref refid="dc/d1b/namespaceaperture_1_1build_1a6a50c75c9bd356f7389b861115a53f80" kindref="member">hole</ref>(</highlight><highlight class="stringliteral">&quot;income&quot;</highlight><highlight class="normal">)<sp/>*<sp/><ref refid="dc/d1b/namespaceaperture_1_1build_1a65b4207ecbcf6370a69baad6d26ae2e6" kindref="member">num</ref>(0.25))<sp/>-<sp/><ref refid="dc/d1b/namespaceaperture_1_1build_1a65b4207ecbcf6370a69baad6d26ae2e6" kindref="member">num</ref>(5000);</highlight></codeline>
