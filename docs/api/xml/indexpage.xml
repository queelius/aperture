</entry><entry thead="no"><para>Double-precision number   </para>
</entry><entry thead="no"><para><computeroutput>42</computeroutput>, <computeroutput>3.14</computeroutput>, <computeroutput>1e-10</computeroutput>    </para>
</entry></row>
<row>
<entry thead="no"><para><computeroutput>Str</computeroutput>   </para>
</entry><entry thead="no"><para>UTF-8 string   </para>
</entry><entry thead="no"><para><computeroutput>&quot;hello world&quot;</computeroutput>    </para>
</entry></row>
<row>
<entry thead="no"><para><computeroutput>Sym</computeroutput>   </para>
</entry><entry thead="no"><para>Symbol/identifier   </para>
</entry><entry thead="no"><para><computeroutput>x</computeroutput>, <computeroutput>+</computeroutput>, <computeroutput>lambda</computeroutput>    </para>
</entry></row>
<row>
<entry thead="no"><para><computeroutput>List</computeroutput>   </para>
