<codeline><highlight class="normal"></highlight><highlight class="keyword">auto</highlight><highlight class="normal"><sp/>verified<sp/>=<sp/><ref refid="df/dc1/namespacesecure" kindref="compound">secure</ref>.verify_holes();<sp/><sp/><sp/><sp/><sp/></highlight><highlight class="comment">//<sp/>Security<sp/>check</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"></highlight><highlight class="keywordtype">double</highlight><highlight class="normal"><sp/></highlight><highlight class="keyword">final</highlight><highlight class="normal"><sp/>=<sp/><ref refid="df/dc1/namespacesecure" kindref="compound">secure</ref>.fill({{</highlight><highlight class="stringliteral">&quot;x&quot;</highlight><highlight class="normal">,<sp/>10}})</highlight></codeline>
